# Azure Settings
COSMOSDB_ENDPOINT="https://your-cosmos-account.documents.azure.com:443/"
# Using Managed Identity for authentication - no key required
COSMOSDB_DATABASE=datacatalog
COSMOSDB_CONTAINER=metadata

# Azure Blob Storage
# Using Managed Identity for authentication - no key required
AZURE_BLOB_ACCOUNT=yourstorageaccount
AZURE_BLOB_CONTAINER=datasets

# Flask Settings
SECRET_KEY=change_this_to_a_random_secret_key
FLASK_ENV=development
